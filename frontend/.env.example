NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Clerk — create an app at https://dashboard.clerk.com and enable Email + Google
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Local/dev only — same value as backend's ADMIN_API_KEY. Attached automatically
# as X-Admin-Key on every /api/admin/* call so /admin opens with no login screen.
# This is bundled into client-side JS (NEXT_PUBLIC_*), so it's a dev convenience,
# not real access control — the backend's require_admin check is what actually
# protects the admin API. Do not commit a real key here or in .env.local.
NEXT_PUBLIC_ADMIN_API_KEY=
