# Required
GROQ_API_KEY=
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# CV OCR (Mistral OCR 3) — resume upload/parsing
MISTRAL_API_KEY=

# Separate key/quota for the mock-interview LLM (question gen, evaluation, summary)
MISTRAL_API_KEY2=

# Separate key/quota for learning-curriculum generation only. Falls back to
# MISTRAL_API_KEY2 if unset (shares that quota instead of its own).
MISTRAL_API_KEY3=

# Protects POST /api/admin/* (scrape trigger, user dossier, verification)
ADMIN_API_KEY=

# Optional — voice mock interview (Google Cloud TTS/STT). Falls back to
# edge-tts (free neural voice) + text-only mode if unset.
GOOGLE_APPLICATION_CREDENTIALS=

# Optional — separate Groq key/quota for voice STT (Whisper)
GROQ_API_KEY2=

# Optional — only needed if HuggingFace rate-limits anonymous model downloads
HF_TOKEN=
