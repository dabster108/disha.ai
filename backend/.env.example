# =============================================================================
# DISHA AI — Backend environment variables
# Copy this file to .env and fill in real values. Never commit .env.
#   cp .env.example .env
#
# Minimum to run the API: GROQ_API_KEY + DATABASE_URL
# =============================================================================

# --- Required ----------------------------------------------------------------
GROQ_API_KEY=gsk_your_groq_key_here
DATABASE_URL=postgresql+asyncpg://user:password@host.neon.tech/dbname?sslmode=require

# --- Voice STT (Groq Whisper — tried before Google STT fallback) -------------
GROQ_API_KEY2=gsk_your_second_groq_key_here
# GROQ_WHISPER_MODEL=whisper-large-v3

# --- CV / resume upload (Mistral OCR) ----------------------------------------
MISTRAL_API_KEY=your_mistral_key_here

# --- Interview LLM (separate quota from OCR; steadier structured output) -----
MISTRAL_API_KEY2=your_second_mistral_key_here

# --- Admin scrape API (optional — /api/admin/* returns 503 when unset) -------
ADMIN_API_KEY=change-me-to-a-long-random-secret

# --- Google Cloud voice (optional — TTS/STT) ---------------------------------
# If unset, TTS uses edge-tts (free default, no API key). STT falls back to Groq Whisper.
# Absolute path to service account JSON on your machine
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/gcp-service-account.json

# --- Optional overrides (defaults shown) -------------------------------------
# GROQ_MODEL=llama-3.1-8b-instant
# MISTRAL_OCR_MODEL=mistral-ocr-2512
# INTERVIEW_MISTRAL_MODEL=mistral-small-latest
# PRACTICE_GROQ_MODEL=llama-3.1-8b-instant
# PRACTICE_PASS_THRESHOLD=7.0
# GAP_N_JOBS=20
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# MIN_JOB_SIMILARITY=0.42
# GOOGLE_TTS_LANGUAGE_CODE=en-US
# GOOGLE_TTS_VOICE_NAME=en-US-Standard-C
# GOOGLE_STT_LANGUAGE_CODE=en-US
# EDGE_TTS_VOICE=en-US-JennyNeural
